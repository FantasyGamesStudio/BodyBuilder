# ── apps/api/.env (desarrollo local) ──────────────────────────────────────────

# Base de datos (requerido)
DATABASE_URL=postgresql://bodybuilder:bodybuilder@localhost:5432/bodybuilder

# OpenAI (requerido para el asesor IA)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# JWT
JWT_SECRET=cambia-esto-en-produccion
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES_DAYS=30

# Servidor
API_HOST=0.0.0.0
API_PORT=3000

# Mock suscripción (ver docs/monetization_mock.md)
MOCK_SUBSCRIPTION=false

# Redis (BullMQ — cola de trabajos IA)
REDIS_URL=redis://localhost:6379

# S3/MinIO (almacenamiento de medios)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minio
S3_SECRET_KEY=minio12345
S3_BUCKET=bodybuilder
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true

# ── apps/web/.env (desarrollo local) ──────────────────────────────────────────
# Vacío en dev: el proxy de Vite redirige /v1 → localhost:3000
# En producción (Vercel) configurar: VITE_API_URL=https://tu-api.railway.app
